{
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/privacy.txt",
      "dest": "/privacy.txt"
    },
    {
      "src": "/terms.txt",
      "dest": "/terms.txt"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
