# =========================================================================
#                    VaultBank Environment Configuration Template
# =========================================================================
# Copy this file to:
# 1. /server/.env (for Backend configurations)
# 2. /client/.env (for Frontend configurations)
# =========================================================================

# -------------------------------------------------------------------------
# BACKEND SERVER CONFIGURATION (Save as /server/.env)
# -------------------------------------------------------------------------
PORT=5000
MONGODB_URI=mongodb://localhost:27017/vaultbank
JWT_SECRET=your_jwt_signing_key_here
CLIENT_URL=http://localhost:5173

# Google OAuth Credentials (obtain from https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Email Notifications SMTP Configuration (Gmail: use App Password from https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_app_password


# -------------------------------------------------------------------------
# FRONTEND CLIENT CONFIGURATION (Save as /client/.env)
# -------------------------------------------------------------------------
VITE_API_URL=http://localhost:5000/api
